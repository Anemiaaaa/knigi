def insert_card(self):
    # Очищаем старые карточки
    while self.ui.verticalLayout_4.count():
        item = self.ui.verticalLayout_4.takeAt(0)
        if item.widget():
            item.widget().deleteLater()

    books = dao.get_all_books()

    for book in books:
        card = CardWindow(book)
        card.clicked.connect(self.najal)
        self.ui.verticalLayout_4.addWidget(card)



def mousePressEvent(self, event: QMouseEvent):
        self.clicked.emit(self.book)
        super().mousePressEvent(event)

 # фильтруем согласно комбо боксу
def filter_orders(self):
    status = self.ui.comboBox.currentText()
    if status == "Все заказы":
        self.show_orders(self.all_orders)
    else:
        filtered = [o for o in self.all_orders if o["order_status"] == status]
        self.show_orders(filtered)



 def change_status(self, index):
    row = index.row()
    model = self.ui.tableView.model()
    order_id = int(model.item(row, 0).text())  # колонка 0 = ID


    status, ok = QInputDialog.getItem(
        self, "Статус", "Выбери статус:",
        ["new", "done", "cancelled"], editable=False
    )

    if ok:
        dao.update_order_status(order_id, status)
        self.load_orders()


def confirm_order(self):
    if self.order_item_model.columnCount() == 0:
        QMessageBox.information(self, "Ошибка", "Добавьте товары в заказ")
        return

    games = []
    total_sum = 0

    for i in range(self.order_item_model.rowCount()):
        price = float(self.order_item_model.item(i, 2).text())
        total_sum += price
        games.append({
            "game_id": self.order_item_model.item(i, 3).text()
        })

    dao.create_order(self.user_id, total_sum, games)
    QMessageBox.information(self, "Успех", f"Заказ на сумму {total_sum} создан.")
    self.load_client_orders()
    self.order_item_model.removeRows(0, self.order_item_model.rowCount())

def create_order(self, user_id, total_sum, games):
    with self.cursor() as cur:
        cur.execute("insert into orders(user_id, total_sum, order_status) values"
                    "(%s, %s, %s)", (user_id, total_sum, "new"))

        order_id = cur.lastrowid

        for game in games:
            cur.execute("insert into order_items(order_id, game_id, quantity) values"
                        "(%s, %s, %s)", (order_id, game["game_id"], 1))

    self.conn.commit()


def add_order_item(self, game):
    self.selected = game
    QMessageBox.information(self, "Инфо", "Товар добавлен ")
    row = [
        QStandardItem(str(game["game_name"])),
        QStandardItem(str(game["genre"])),
        QStandardItem(str(game["price"])),
        QStandardItem(str(game["game_id"])),
    ]

    self.order_item_model.appendRow(row)

    def add_image(self):
        path, _ = QFileDialog.getOpenFileName(self, "Выберите фото", "image/", "All Files (*)")
        if path:
            self.ui.imageLineEdit.setText(path)